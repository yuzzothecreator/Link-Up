# Copy to .env.local (local) and Vercel → Settings → Environment Variables (Production).
# Never commit real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
SESSION_SECRET=
# Local seed OTP only. NEVER set true in Production.
ALLOW_TEST_OTP=false

# Real staff phones (bootstrap once, then login via Briq OTP)
# BOOTSTRAP_ADMIN_PHONE=+2557XXXXXXXX
# BOOTSTRAP_ADMIN_NAME=Platform Admin
# BOOTSTRAP_LENDER_PHONE=+2557YYYYYYYY
# BOOTSTRAP_LENDER_NAME=Provider Underwriter
# BOOTSTRAP_LENDER_ORG=Link-Up Partner Bank

# --- App URL (must be public HTTPS in production) ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Briq SMS ---
BRIQ_API_KEY=
# Use exactly: BRIQ OTP  (approved default). Do not use Link-Up / LINKUP.
BRIQ_SENDER_ID=BRIQ OTP
# Optional live SMS health checks: header x-health-secret
# HEALTH_SMS_SECRET=

# --- TemboPlus payments ---
TEMBO_ACCOUNT_ID=
TEMBO_SECRET_KEY=
TEMBO_WEBHOOK_SECRET=
# Optional: TEMBO_BASE_URL=https://sandbox.temboplus.com/tembo/v1

# --- Optional NIDA gateway ---
# NIDA_API_URL=
# NIDA_API_KEY=
